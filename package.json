{
  "name": "teammeet",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@teammeet/web",
    "dev:web": "turbo run dev --filter=@teammeet/web",
    "dev:mobile": "bun run --cwd apps/mobile start",
    "mobile:start:dev-client": "bun run --cwd apps/mobile start:dev-client",
    "mobile:prebuild": "bun run --cwd apps/mobile prebuild",
    "mobile:prebuild:clean": "bun run --cwd apps/mobile prebuild:clean",
    "mobile:ios": "bun run --cwd apps/mobile ios",
    "mobile:android": "bun run --cwd apps/mobile android",
    "mobile:android:doctor": "bun run --cwd apps/mobile android:doctor",
    "mobile:run:ios": "bun run --cwd apps/mobile run:ios",
    "mobile:run:android": "bun run --cwd apps/mobile run:android",
    "mobile:config": "bun run --cwd apps/mobile config",
    "mobile:config:introspect": "bun run --cwd apps/mobile config:introspect",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@teammeet/web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test --filter=@teammeet/web",
    "test:auth": "turbo run test:auth --filter=@teammeet/web",
    "test:payments": "turbo run test:payments --filter=@teammeet/web",
    "test:security": "turbo run test:security --filter=@teammeet/web",
    "test:e2e": "npx playwright test --project=e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "prettier": "^3.8.1",
    "turbo": "^2",
    "typescript": "^5.9.2"
  },
  "patchedDependencies": {
    "expo-image-picker@55.0.12": "patches/expo-image-picker@55.0.12.patch"
  }
}
