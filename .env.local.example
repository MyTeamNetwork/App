# Core app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
# Optional locally, required on Vercel production when using donation webhooks
STRIPE_WEBHOOK_SECRET_CONNECT=your-stripe-connect-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Organization subscription price IDs
STRIPE_PRICE_BASE_MONTHLY=price_xxx
STRIPE_PRICE_BASE_YEARLY=price_xxx
STRIPE_PRICE_ALUMNI_0_250_MONTHLY=price_xxx
STRIPE_PRICE_ALUMNI_0_250_YEARLY=price_xxx
STRIPE_PRICE_ALUMNI_251_500_MONTHLY=price_xxx
STRIPE_PRICE_ALUMNI_251_500_YEARLY=price_xxx
STRIPE_PRICE_ALUMNI_501_1000_MONTHLY=price_xxx
STRIPE_PRICE_ALUMNI_501_1000_YEARLY=price_xxx
STRIPE_PRICE_ALUMNI_1001_2500_MONTHLY=price_xxx
STRIPE_PRICE_ALUMNI_1001_2500_YEARLY=price_xxx
STRIPE_PRICE_ALUMNI_2500_5000_MONTHLY=price_xxx
STRIPE_PRICE_ALUMNI_2500_5000_YEARLY=price_xxx

# Enterprise price IDs
STRIPE_PRICE_ENTERPRISE_ALUMNI_BUCKET_MONTHLY=price_xxx
STRIPE_PRICE_ENTERPRISE_ALUMNI_BUCKET_YEARLY=price_xxx
STRIPE_PRICE_ENTERPRISE_SUB_ORG_MONTHLY=price_xxx
STRIPE_PRICE_ENTERPRISE_SUB_ORG_YEARLY=price_xxx

# hCaptcha
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key
HCAPTCHA_SECRET_KEY=your-hcaptcha-secret-key

# Email / notifications
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=noreply@myteamnetwork.com
ADMIN_EMAIL=admin@myteamnetwork.com
ALERT_EMAIL_TO=alerts@example.com

# Cron
# Optional locally, required on Vercel production
CRON_SECRET=your-cron-secret

# Google Calendar integration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_TOKEN_ENCRYPTION_KEY=your-google-token-encryption-key

# LinkedIn connected accounts (profile sync)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_TOKEN_ENCRYPTION_KEY=your-linkedin-token-encryption-key

# Apple Universal Links (iOS) — Team ID prefix injected into the AASA
# response at /.well-known/apple-app-site-association. Get from
# developer.apple.com → Membership → Team ID. Without this, AASA
# serves the placeholder TEAMID0000 and Universal Links won't activate
# for any installed app.
APPLE_APP_ID_PREFIX=your-10-char-team-id

# Apple Push Notifications (P3 — Wallet pass updates + Live Activities).
# APNs HTTP/2 token-based auth using a .p8 key from
# developer.apple.com → Keys → APNs. Store the .p8 file contents as
# base64-encoded text in APNS_AUTH_KEY (decode at boot). Not yet
# load-bearing — push fan-out today goes through Expo, which proxies
# APNs internally. Required when R6/R7 ship.
APNS_KEY_ID=your-10-char-key-id
APNS_TEAM_ID=your-10-char-team-id
APNS_AUTH_KEY=base64-encoded-p8-contents

# Apple Wallet pass signing (P3 R6 — .pkpass member passes). Pass Type
# ID cert + WWDR intermediate, both base64-encoded. Distinct from the
# APNs .p8 above — Apple uses two unrelated cert systems for these.
APPLE_PASS_TYPE_ID=pass.com.myteamnetwork.member
APPLE_PASS_TEAM_ID=your-10-char-team-id
APPLE_PASS_SIGNER_CERT_BASE64=base64-encoded-signer-cert
APPLE_PASS_SIGNER_KEY_BASE64=base64-encoded-signer-key
APPLE_PASS_SIGNER_KEY_PASSWORD=password-for-signer-key
APPLE_WWDR_CERT_BASE64=base64-encoded-wwdr-intermediate

# Mobile (Expo) — used in apps/mobile/.env.local
# EXPO_PUBLIC_SUPABASE_URL=your-supabase-url
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# EXPO_PUBLIC_POSTHOG_KEY=your-posthog-key
# EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Development toggles
# SKIP_STRIPE_VALIDATION=true
# NEXT_PUBLIC_DEBUG=true
# LOG_AUTH_VERBOSE=true
# LOG_AUTH_FAILURES=true
